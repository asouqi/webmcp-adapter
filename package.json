{
  "name": "webmcp-adapter",
  "version": "0.1.0",
  "description": "Lightweight adapter for WebMCP — define, register, and manage AI agent tools with built-in schema validation and error handling.  ",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mcp-b/global": ">=2.0.0"
  },
  "devDependencies": {
    "@mcp-b/global": "^2.2.0",
    "@mcp-b/webmcp-types": "^2.2.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  },
  "keywords": [
    "webmcp",
    "mcp",
    "ai-agent",
    "browser"
  ],
  "license": "MIT"
}